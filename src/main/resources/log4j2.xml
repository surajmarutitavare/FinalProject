<?xml version="1.0" encoding="UTF-8"?>
<!-- Log4j2 setup -->
<Configuration status="WARN">

    <!-- Where to send logs -->
    <Appenders>

        <!-- Show logs on screen -->
        <Console name="Console" target="SYSTEM_OUT">
            <!-- Format: Date Time Level Class Message -->
            <PatternLayout
                    pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level [%c{1}] - %msg%n"/>
        </Console>

        <!-- Save logs to file -->
        <File name="FileLogger"
              fileName="logs/automation.log"
              append="true">
            <!-- Use same format for file -->
            <PatternLayout
                    pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level [%c{1}] - %msg%n"/>
        </File>

    </Appenders>

    <!-- Logger settings -->
    <Loggers>
        <!-- Main logger for all logs -->
        <Root level="info">
            <!-- Send logs to screen -->
            <AppenderRef ref="Console"/>
            <!-- Send logs to file -->
            <AppenderRef ref="FileLogger"/>
        </Root>
    </Loggers>

</Configuration>